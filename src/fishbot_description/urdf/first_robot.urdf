<?xml version="1.0"?>
<robot name="first_robot">
    <material name="blue">
        <color rgba="0.1 0.1 1.0 0.5" />
    </material>
    <material name="green">
        <color rgba="0.1 1.0 0.1 0.5"/>
    </material>
    <link name="base_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.12" radius="0.1"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>   
            <geometry>
                <cylinder length="0.12" radius="0.1"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.5"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>      
        </inertial>
    </link>

    <link name="imu_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.02 0.02 0.02" />
            </geometry>
            <material name="green"/>
        </visual>
        <collision> 
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.02 0.02 0.02" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.5"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>      
        </inertial>
    </link>

    <joint name="imu_joint" type="fixed">
        <parent link="base_link"/>
        <child link="imu_link"/>
        <origin xyz="0 0 0.07" rpy="0 0 0"/>
        <axis xyz="0 0 1" />
    </joint>

</robot>